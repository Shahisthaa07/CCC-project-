#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 100

typedef struct {
    char name[50];
    int cost;
    int profit;
    float ratio;
} Ad;

// Comparator for greedy sorting
int compare(const void *a, const void *b) {
    Ad *ad1 = (Ad *)a;
    Ad *ad2 = (Ad *)b;
    if (ad2->ratio > ad1->ratio)
        return 1;
    else if (ad2->ratio < ad1->ratio)
        return -1;
    else
        return 0;
}

// Greedy Algorithm
void greedyAds(Ad ads[], int n, int budget) {
    Ad sorted[MAX];
    for (int i = 0; i < n; i++) {
        sorted[i] = ads[i];
        sorted[i].ratio = (float)ads[i].profit / ads[i].cost;
    }

    qsort(sorted, n, sizeof(Ad), compare);

    int totalCost = 0, totalProfit = 0;

    printf("\n--- GREEDY RESULT ---\n");
    printf("Selected Ads:\n");

    for (int i = 0; i < n; i++) {
        if (totalCost + sorted[i].cost <= budget) {
            printf("%s (Cost=%d, Profit=%d)\n", sorted[i].name, sorted[i].cost, sorted[i].profit);
            totalCost += sorted[i].cost;
            totalProfit += sorted[i].profit;
        }
    }

    printf("Total Profit: %d\n", totalProfit);
}

// DP (0/1 Knapsack)
void dpAds(Ad ads[], int n, int budget) {
    int dp[MAX][MAX] = {0};

    for (int i = 1; i <= n; i++) {
        for (int w = 0; w <= budget; w++) {
            if (ads[i-1].cost <= w) {
                int include = ads[i-1].profit + dp[i-1][w - ads[i-1].cost];
                int exclude = dp[i-1][w];
                dp[i][w] = include > exclude ? include : exclude;
            } else {
                dp[i][w] = dp[i-1][w];
            }
        }
    }

    printf("\n--- DYNAMIC PROGRAMMING RESULT ---\n");
    printf("Selected Ads:\n");

    int w = budget;
    int totalProfit = dp[n][budget];

    for (int i = n; i > 0; i--) {
        if (dp[i][w] != dp[i-1][w]) {
            printf("%s (Cost=%d, Profit=%d)\n", ads[i-1].name, ads[i-1].cost, ads[i-1].profit);
            w -= ads[i-1].cost;
        }
    }

    printf("Total Profit: %d\n", totalProfit);
}

int main() {
    int n, budget;
    Ad ads[MAX];

    printf("\n📊 SMART AD OPTIMIZATION SYSTEM (C)\n");

    printf("Enter number of ads: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("\nAd %d:\n", i + 1);
        printf("Name: ");
        scanf("%s", ads[i].name);
        printf("Cost: ");
        scanf("%d", &ads[i].cost);
        printf("Profit: ");
        scanf("%d", &ads[i].profit);
    }

    printf("\nEnter total budget: ");
    scanf("%d", &budget);

    greedyAds(ads, n, budget);
    dpAds(ads, n, budget);

    return 0;
}
